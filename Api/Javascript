export default async function handler(req, res) {
    const { url } = req.query;
    if (!url) return res.status(400).json({ error: "No URL" });

    // Use fresh community nodes from cobalt.best
    const nodes = [
        "https://cobalt.meowing.de", 
        "https://cobalt.canine.tools",
        "https://cobalt-api.v06.io"
    ];

    for (let node of nodes) {
        try {
            const response = await fetch(node, {
                method: "POST",
                headers: { "Content-Type": "application/json", "Accept": "application/json" },
                body: JSON.stringify({ url: url, videoQuality: "720" })
            });
            const data = await response.json();
            if (data.url) return res.status(200).json({ downloadUrl: data.url });
        } catch (err) { continue; }
    }
    return res.status(500).json({ error: "YouTube has blocked all available nodes." });
}
