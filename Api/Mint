import express from "express";
import { createClient } from "@supabase/supabase-js";
import { ethers } from "ethers";

const app = express();
app.use(express.json());

const supabase = createClient(
  "https://ipumbyywyzrbinwtejri.supabase.co",
  "YOUR_SERVICE_ROLE_KEY"
);

// 🔗 Ethereum RPC
const provider = new ethers.JsonRpcProvider("https://eth.llamarpc.com");

// 🔒 YOUR CONTRACT
const CONTRACT_ADDRESS = "YOUR_CONTRACT_ADDRESS";

// ABI (must include mint + price)
const CONTRACT_ABI = [
  "function getMintPrice() view returns (uint256)",
  "function mint() payable"
];

const contract = new ethers.Contract(CONTRACT_ADDRESS, CONTRACT_ABI, provider);

app.post("/api/mint", async (req, res) => {
  const { wallet, txHash } = req.body;

  if (!wallet || !txHash) {
    return res.status(400).json({ error: "Missing wallet or txHash" });
  }

  try {
    // ✅ 1. Prevent reuse
    const { data: existing } = await supabase
      .from("sims")
      .select("id")
      .eq("tx_hash", txHash)
      .maybeSingle();

    if (existing) {
      return res.status(400).json({ error: "Transaction already used" });
    }

    // ✅ 2. Get transaction
    const tx = await provider.getTransaction(txHash);
    const receipt = await provider.getTransactionReceipt(txHash);

    if (!tx || !receipt) {
      return res.status(400).json({ error: "Invalid transaction" });
    }

    // ✅ 3. Must be successful
    if (receipt.status !== 1) {
      return res.status(400).json({ error: "Transaction failed" });
    }

    // ✅ 4. Verify sender
    if (tx.from.toLowerCase() !== wallet.toLowerCase()) {
      return res.status(400).json({ error: "Wallet mismatch" });
    }

    // ✅ 5. Verify contract address
    if (!tx.to || tx.to.toLowerCase() !== CONTRACT_ADDRESS.toLowerCase()) {
      return res.status(400).json({ error: "Not sent to contract" });
    }

    // ✅ 6. Verify mint price
    const mintPrice = await contract.getMintPrice();

    if (tx.value < mintPrice) {
      return res.status(400).json({ error: "Insufficient payment" });
    }

    // ✅ 7. OPTIONAL: verify function call = mint()
    const iface = new ethers.Interface(CONTRACT_ABI);
    const decoded = iface.parseTransaction({ data: tx.data });

    if (!decoded || decoded.name !== "mint") {
      return res.status(400).json({ error: "Invalid function call" });
    }

    // ✅ 8. Get available SIM
    const { data: sims } = await supabase
      .from("sims")
      .select("*")
      .eq("status", "available")
      .limit(1);

    if (!sims || sims.length === 0) {
      return res.status(400).json({ error: "No SIMs available" });
    }

    const sim = sims[0];

    // ✅ 9. Assign SIM
    await supabase
      .from("sims")
      .update({
        status: "used",
        assigned_to: wallet,
        tx_hash: txHash
      })
      .eq("id", sim.id);

    // ✅ 10. Success
    res.json({
      success: true,
      sim: sim.iccid,
      tokenId: sim.id
    });

  } catch (err) {
    console.error(err);
    res.status(500).json({ error: "Server error" });
  }
});

app.listen(3000, () => console.log("🚀 Fully secure API running"));